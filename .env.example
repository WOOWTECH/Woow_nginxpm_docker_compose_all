# Nginx Proxy Manager Docker Compose Configuration
# Copy this file to .env and update the values
# 複製此檔案為 .env 並更新設定值

# PostgreSQL Configuration / PostgreSQL 資料庫設定
POSTGRES_USER=npm
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=npm

# Nginx Proxy Manager Ports / Nginx Proxy Manager 連接埠設定
NPM_HTTP_PORT=80
NPM_HTTPS_PORT=443
NPM_ADMIN_PORT=81

# Timezone / 時區設定
TZ=Asia/Taipei
